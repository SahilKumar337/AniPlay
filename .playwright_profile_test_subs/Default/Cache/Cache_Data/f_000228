[{"startTime":2.73,"endTime":4.77,"text":"<i>Wealth, fame, power...</i>"},{"startTime":4.77,"endTime":6.67,"text":"<i>Gold Roger,\nthe King of the Pirates,</i>"},{"startTime":6.67,"endTime":8.97,"text":"<i>attained everything\nthis world has to offer.</i>"},{"startTime":8.97,"endTime":12.84,"text":"<i>The words he uttered just before\nhis death drove people to the seas.</i>"},{"startTime":12.84,"endTime":16.68,"text":"<i>My treasure? If you want it,\nyou can have it!</i>"},{"startTime":16.68,"endTime":20.24,"text":"<i>Find it! I left everything\nthis world has to offer there!</i>"},{"startTime":22.85,"endTime":27.59,"text":"<i>And so men head for the Grand Line\nin pursuit of their dreams!</i>"},{"startTime":27.59,"endTime":31.49,"text":"<i>The world has truly entered\na Great Pirate Era!</i>"},{"startTime":31.49,"endTime":36.86,"text":"<i>We're going to gather up\nall our dreams</i>"},{"startTime":36.86,"endTime":42.77,"text":"<i>and set out in search\nof something to find</i>"},{"startTime":42.77,"endTime":44.1,"text":"<i>ONE PIECE!</i>"},{"startTime":49.04,"endTime":54.62,"text":"<i>Compasses only cause delays</i>"},{"startTime":54.62,"endTime":60.35,"text":"<i>Delirious with fever,\nI take the helm</i>"},{"startTime":60.35,"endTime":70.35,"text":"<i>If the dusty treasure map has\nbeen verified, it's not a legend!</i>"},{"startTime":72.47,"endTime":78.17,"text":"<i>When it comes to personal storms,</i>"},{"startTime":78.17,"endTime":83.48,"text":"<i>simply ride aboard\nsomeone else's biorhythm</i>"},{"startTime":83.48,"endTime":87.15,"text":"<i>and pretend it isn't there!</i>"},{"startTime":87.15,"endTime":92.65,"text":"<i>We're going to gather up\nall our dreams</i>"},{"startTime":92.65,"endTime":98.36,"text":"<i>and set out in search\nof something to find</i>"},{"startTime":98.36,"endTime":104.6,"text":"<i>A coin in my pocket,\nand do you wanna be my friend?</i>"},{"startTime":104.6,"endTime":109.97,"text":"<i>We are, We are on the cruise!</i>"},{"startTime":109.97,"endTime":111.04,"text":"<i>We are!</i>"},{"startTime":126.09,"endTime":127.68,"text":"Fire!"},{"startTime":138,"endTime":139.53,"text":"What are you-?!"},{"startTime":139.53,"endTime":141.24,"text":"<i>Luffy-san!</i>"},{"startTime":141.24,"endTime":142.86,"text":"Straw Hat?!"},{"startTime":148.34,"endTime":151.34,"text":"That doesn't work!"},{"startTime":155.58,"endTime":158.92,"text":"I told you I was strong!"},{"startTime":158.92,"endTime":162.42,"text":"W-who the hell are you?!"},{"startTime":162.42,"endTime":164.03,"text":"I'm Luffy!"},{"startTime":164.03,"endTime":167.29,"text":"The man who's gonna\nbe King of the Pirates!"},{"startTime":167.29,"endTime":176.03,"text":"\"Morgan vs. Luffy!\nWho's the Mysterious Pretty Girl?\""},{"startTime":177.27,"endTime":181.41,"text":"W-what?!\nThe King of the Pirates?!"},{"startTime":181.41,"endTime":185.11,"text":"Do you even know\nwhat that means?!"},{"startTime":185.11,"endTime":187.55,"text":"King of the Pirates\nis King of the Pirates!"},{"startTime":187.55,"endTime":189.61,"text":"Are there any other meanings?"},{"startTime":192.12,"endTime":193.65,"text":"I was shocked, too!"},{"startTime":193.65,"endTime":197.22,"text":"<i>But Luffy-san is serious!\nThat's how he is!</i>"},{"startTime":197.22,"endTime":199.23,"text":"He intends to become\nthe King of the Pirates"},{"startTime":199.23,"endTime":203.93,"text":"and obtain this world's ultimate\ntreasure... the One Piece!"},{"startTime":207.7,"endTime":209.8,"text":"Here's your treasure!"},{"startTime":209.8,"endTime":213.54,"text":"Which is yours? I couldn't tell,\nso I brought three of 'em."},{"startTime":213.54,"endTime":215.68,"text":"All three are mine."},{"startTime":215.68,"endTime":218.01,"text":"I use the Three-Sword Style."},{"startTime":220.15,"endTime":221.15,"text":"You'll take 'em, right?"},{"startTime":221.15,"endTime":223.15,"text":"If we fight together now,"},{"startTime":223.15,"endTime":225.49,"text":"you'll be\na government-defying villain!"},{"startTime":225.49,"endTime":229.46,"text":"Would you prefer that, or being\nkilled by the navy like this?"},{"startTime":229.46,"endTime":231.69,"text":"What are you, the devil's son?!"},{"startTime":231.69,"endTime":233.03,"text":"Well, whatever."},{"startTime":233.03,"endTime":237.83,"text":"I'll be your pirate,\nif I'm just gonna die here instead!"},{"startTime":237.83,"endTime":241.5,"text":"Hurray! So you'll join my crew?!"},{"startTime":241.5,"endTime":244.04,"text":"Alright! Woo-hoo!\nThis is great! Alright!"},{"startTime":244.04,"endTime":247.34,"text":"Okay! Now untie these\nstupid ropes already!"},{"startTime":247.34,"endTime":248.94,"text":"What... is he?"},{"startTime":248.94,"endTime":251.35,"text":"He flung the bullets back!"},{"startTime":251.35,"endTime":253.95,"text":"He's no ordinary human,\nthat Straw Hat..."},{"startTime":253.95,"endTime":257.49,"text":"Must've eaten one of those\nrumored Devil Fruits!"},{"startTime":257.49,"endTime":260.48,"text":"--A Devil Fruit?!\n--The hidden treasures of the sea?!"},{"startTime":262.59,"endTime":264.56,"text":"The Devil Fruits..."},{"startTime":264.56,"endTime":269.22,"text":"Whoever eats one is said to gain\nseemingly unworldly abilities."},{"startTime":271.1,"endTime":273.3,"text":"The power to breathe fire..."},{"startTime":273.3,"endTime":275.6,"text":"The power to cause tsunamis..."},{"startTime":275.6,"endTime":277.67,"text":"There are all sorts of rumors,"},{"startTime":277.67,"endTime":281.61,"text":"but there are many types, and\nalmost nothing is known about them."},{"startTime":281.61,"endTime":286.35,"text":"It's said the secrets to\nthem lie in the Grand Line..."},{"startTime":286.35,"endTime":291.32,"text":"...but there's no question Straw\nHat just displayed a devil power!"},{"startTime":291.32,"endTime":292.92,"text":"Hurry! Hurry!"},{"startTime":292.92,"endTime":295.16,"text":"Damn! These knots are tight!"},{"startTime":295.16,"endTime":296.96,"text":"Hey! Quit wastin' time!"},{"startTime":296.96,"endTime":298.79,"text":"<i>No matter who they are,</i>"},{"startTime":298.79,"endTime":301.43,"text":"everyone who opposes\nme gets executed!"},{"startTime":301.43,"endTime":303.95,"text":"If guns won't work,\nthen chop them to death!"},{"startTime":307.97,"endTime":310.64,"text":"Huh, that's weird!\nIt got tighter instead!"},{"startTime":310.64,"endTime":312.47,"text":"Give me a damn sword!"},{"startTime":315.41,"endTime":316.74,"text":"<i>Luffy-san!</i>"},{"startTime":325.65,"endTime":327.42,"text":"Roronoa Zoro!"},{"startTime":328.82,"endTime":330.49,"text":"So cool!"},{"startTime":331.79,"endTime":334.4,"text":"Move and you're dead."},{"startTime":334.4,"endTime":336.19,"text":"Too scary!"},{"startTime":340.23,"endTime":343.37,"text":"I'll be a pirate.\nI promise you that."},{"startTime":343.37,"endTime":347.11,"text":"I'm officially a criminal,\nnow that I've fought the navy."},{"startTime":347.11,"endTime":349.68,"text":"But I'll tell you this right now."},{"startTime":349.68,"endTime":352.41,"text":"<i>I'm only going to\nfulfill my ambition!</i>"},{"startTime":352.41,"endTime":353.65,"text":"Ambition?"},{"startTime":353.65,"endTime":356.98,"text":"To be the world's\ngreatest swordsman!"},{"startTime":356.98,"endTime":360.19,"text":"If I wind up having\nto give that up,"},{"startTime":360.19,"endTime":364.53,"text":"you'd better accept responsibility\nand apologize to me!"},{"startTime":364.53,"endTime":368.06,"text":"The world's greatest swordsman?\nThat sounds great!"},{"startTime":368.06,"endTime":372.53,"text":"The King of the Pirates would need\nno less than that on his crew!"},{"startTime":372.53,"endTime":373.9,"text":"You sure talk big."},{"startTime":373.9,"endTime":376.7,"text":"At this point, whether it's as\na criminal or whatever else,"},{"startTime":376.7,"endTime":379.64,"text":"<i>I will spread my name\nthroughout the world!</i>"},{"startTime":379.64,"endTime":384.31,"text":"What're you standing around for?!\nSlaughter them this instant!"},{"startTime":385.31,"endTime":387.92,"text":"Duck, Zoro!"},{"startTime":387.92,"endTime":392.18,"text":"Gum-Gum Whip!"},{"startTime":394.42,"endTime":397.16,"text":"Y-you did it! Incredible!"},{"startTime":397.16,"endTime":399.33,"text":"What the hell are you?"},{"startTime":399.33,"endTime":402.26,"text":"I ate the Gum-Gum Fruit."},{"startTime":402.26,"endTime":403.9,"text":"Gum-Gum Fruit?"},{"startTime":403.9,"endTime":405.4,"text":"A rubber person!"},{"startTime":405.4,"endTime":407.94,"text":"<i>So he does have\nDevil Fruit powers!</i>"},{"startTime":407.94,"endTime":410.27,"text":"Captain! We don't stand\na chance against them!"},{"startTime":410.27,"endTime":411.74,"text":"These guys are crazy!"},{"startTime":411.74,"endTime":414.07,"text":"We can't even handle\nZoro by himself!"},{"startTime":416.61,"endTime":418.41,"text":"This is a direct order!"},{"startTime":418.41,"endTime":420.25,"text":"Everyone who spouted\nweakness just now..."},{"startTime":420.25,"endTime":422.25,"text":"...must now shoot themselves\nin the head!"},{"startTime":422.25,"endTime":425.28,"text":"I have no need for\nweakling soldiers!"},{"startTime":427.96,"endTime":431.29,"text":"These troops are mental!"},{"startTime":431.29,"endTime":432.62,"text":"<i>Luffy-san!</i>"},{"startTime":434.63,"endTime":437.62,"text":"Crush this navy!"},{"startTime":446.07,"endTime":450.88,"text":"Rankless, low-status bums have\nno right whatsoever to defy me!"},{"startTime":450.88,"endTime":454.78,"text":"I am Navy Captain\n\"Axe-Hand\" Morgan!"},{"startTime":454.78,"endTime":457.58,"text":"I'm Luffy!\nNice to meetcha!"},{"startTime":457.58,"endTime":459.58,"text":"Die!"},{"startTime":468.9,"endTime":470.63,"text":"T-the captain!"},{"startTime":470.63,"endTime":473.1,"text":"R-runt..."},{"startTime":475.2,"endTime":477.2,"text":"Die!"},{"startTime":477.2,"endTime":478.54,"text":"No thanks!"},{"startTime":481.21,"endTime":483.04,"text":"C-Captain Morgan is..."},{"startTime":485.25,"endTime":486.91,"text":"...being trounced completely..."},{"startTime":488.75,"endTime":490.28,"text":"And you call yourself a navy?!"},{"startTime":490.28,"endTime":492.95,"text":"You've destroyed Coby's dream!"},{"startTime":493.95,"endTime":497.15,"text":"<i>Hold it, Straw Hat!\nCheck this out!</i>"},{"startTime":498.93,"endTime":501.7,"text":"I said hold it!\nAre you stupid?!"},{"startTime":501.7,"endTime":504.87,"text":"Pay attention!\nI have a hostage here!"},{"startTime":504.87,"endTime":506.6,"text":"<i>Helmeppo-sama!</i>"},{"startTime":506.6,"endTime":507.93,"text":"Hey."},{"startTime":509.54,"endTime":512.37,"text":"If you value this guy's life,\ndon't move!"},{"startTime":512.37,"endTime":515.37,"text":"One move and I'll shoot!"},{"startTime":523.08,"endTime":526.99,"text":"<i>Luffy-san! I don't want\nto get in your way!</i>"},{"startTime":526.99,"endTime":528.32,"text":"Even if it means dying!"},{"startTime":528.32,"endTime":530.72,"text":"Yeah, I know!"},{"startTime":530.72,"endTime":532.73,"text":"Give it up, stupid son!"},{"startTime":532.73,"endTime":535.06,"text":"Coby really is ready to die!"},{"startTime":536.23,"endTime":537.4,"text":"Don't move!"},{"startTime":537.4,"endTime":540.23,"text":"I told you not to move!\nI-I'll shoot!"},{"startTime":541.24,"endTime":542.54,"text":"Behind you!"},{"startTime":542.54,"endTime":543.87,"text":"Gum-Gum..."},{"startTime":543.87,"endTime":549.44,"text":"I am Navy Captain\n\"Axe-Hand\" Morgan!"},{"startTime":549.44,"endTime":554.71,"text":"--Dad! Kill him, quick!\n--...Pistol!"},{"startTime":557.25,"endTime":558.58,"text":"Nice!"},{"startTime":567.96,"endTime":569.23,"text":"Zoro."},{"startTime":569.23,"endTime":571.89,"text":"My pleasure, Captain."},{"startTime":579.74,"endTime":581.28,"text":"Captain Morgan's been beaten!"},{"startTime":581.28,"endTime":583.61,"text":"--Unbelievable!\n--These guys are insane!"},{"startTime":585.25,"endTime":588.91,"text":"If anyone else still wants\nto catch us, come forward!"},{"startTime":592.09,"endTime":595.62,"text":"--Hurray!\n--We're free!"},{"startTime":595.62,"endTime":598.06,"text":"--Yahoo!\n--Morgan's reign is over!"},{"startTime":598.06,"endTime":600.53,"text":"Hurray for the navy!"},{"startTime":600.53,"endTime":604.53,"text":"Huh? Everyone's happy their\ncaptain's been beaten..."},{"startTime":604.53,"endTime":607.97,"text":"Everyone was just\nafraid of Morgan!"},{"startTime":612.11,"endTime":615.44,"text":"<i>What's wrong, Zoro-san?!\nAre you hurt?!</i>"},{"startTime":615.44,"endTime":617.97,"text":"I'm... hungry..."},{"startTime":622.88,"endTime":625.05,"text":"Sorry!"},{"startTime":625.05,"endTime":627.04,"text":"Just endure it\nfor a while!"},{"startTime":641.84,"endTime":644.5,"text":"Doesn't seem to be in here,\neither..."},{"startTime":661.32,"endTime":664.49,"text":"Yes! A chart of\nthe Grand Line!"},{"startTime":664.49,"endTime":666.62,"text":"I knew they had one!"},{"startTime":667.73,"endTime":669.26,"text":"\"I've flashily taken the map! Buggy\""},{"startTime":669.26,"endTime":672.1,"text":"\"I've flashily taken the map! Buggy\"\nT-this isn't a chart!\nWhat is this mark?!"},{"startTime":672.1,"endTime":672.26,"text":"T-this isn't a chart!\nWhat is this mark?!"},{"startTime":674.77,"endTime":676.67,"text":"Captain Buggy..."},{"startTime":677.67,"endTime":681.01,"text":"The man known\nas Buggy the Immortal..."},{"startTime":710,"endTime":712.14,"text":"I'm stuffed!"},{"startTime":712.14,"endTime":714.47,"text":"I was definitely at my rope's end,"},{"startTime":714.47,"endTime":716.81,"text":"having not eaten for three weeks!"},{"startTime":720.15,"endTime":723.52,"text":"Huh? You're finished already?"},{"startTime":723.52,"endTime":726.55,"text":"How the heck can you have\na bigger appetite than me?!"},{"startTime":726.55,"endTime":729.32,"text":"It tastes good! Right, Coby?"},{"startTime":729.32,"endTime":732.39,"text":"Thank you for treating\nme to food, too..."},{"startTime":732.39,"endTime":735.73,"text":"<i>It's no problem! The town\nhas been saved, after all!</i>"},{"startTime":735.73,"endTime":738.3,"text":"You really are amazing!"},{"startTime":738.3,"endTime":741.37,"text":"Yep, I am! And I'm gonna\nbe even more amazing!"},{"startTime":741.37,"endTime":744.24,"text":"'Cause I'm gonna be\nKing of the Pirates!"},{"startTime":744.24,"endTime":746.24,"text":"And I even have a crew!"},{"startTime":746.24,"endTime":749.87,"text":"So, how many others have you\ngathered besides me?"},{"startTime":751.88,"endTime":755.58,"text":"You said you were in the\nmiddle of gathering a crew."},{"startTime":755.58,"endTime":757.48,"text":"To be King of the Pirates,"},{"startTime":757.48,"endTime":760.12,"text":"you must have\na good number gathered."},{"startTime":760.12,"endTime":760.89,"text":"Just you."},{"startTime":760.89,"endTime":763.42,"text":"Huh?! Then..."},{"startTime":763.42,"endTime":765.79,"text":"Yep! Just us two!"},{"startTime":765.79,"endTime":768.2,"text":"We're gonna call just\nus two a pirate crew?!"},{"startTime":768.2,"endTime":770.63,"text":"<i>What's wrong with that?\nWe are strong!</i>"},{"startTime":770.63,"endTime":773.67,"text":"What about a ship?\nWhere's your pirate ship?"},{"startTime":773.67,"endTime":775.03,"text":"There."},{"startTime":781.64,"endTime":782.78,"text":"<i>That?</i>"},{"startTime":782.78,"endTime":786.44,"text":"<i>We'll have a ship this big\nbefore long!</i>"},{"startTime":788.42,"endTime":789.88,"text":"And how's that?!"},{"startTime":789.88,"endTime":792.38,"text":"And I'd like a pirate flag, too!"},{"startTime":799.63,"endTime":802.6,"text":"Yeah! Yeah, yeah! So cool!"},{"startTime":802.6,"endTime":807.5,"text":"<i>I think Luffy-san was born\nwithout any sense of planning.</i>"},{"startTime":807.5,"endTime":810.84,"text":"Did I really make this\nguy my captain?!"},{"startTime":810.84,"endTime":814.01,"text":"Well, we'll get more\ncrew members before long!"},{"startTime":814.01,"endTime":818.25,"text":"Hey, hey! Where are you guys\ngonna go to now?"},{"startTime":818.25,"endTime":821.84,"text":"Isn't it obvious?!\nThe Grand Line!"},{"startTime":823.12,"endTime":825.35,"text":"You still only have\ntwo members!"},{"startTime":825.35,"endTime":827.39,"text":"There's no way you\ncan go there!"},{"startTime":827.39,"endTime":828.42,"text":"No way! No way! No way!"},{"startTime":828.42,"endTime":832.03,"text":"Is the Grand Line that\nterrible of a place?"},{"startTime":832.03,"endTime":833.79,"text":"Naturally!"},{"startTime":833.79,"endTime":838.23,"text":"You know this world\nhas two oceans, right?"},{"startTime":838.23,"endTime":842.8,"text":"And the giant continent that cuts\nthem right in two is the Red Line."},{"startTime":842.8,"endTime":846.07,"text":"Supposedly, there's a town right\nin the middle of the Red Line,"},{"startTime":846.07,"endTime":850.54,"text":"and the Grand Line goes\nthrough it at a right angle..."},{"startTime":850.54,"endTime":854.05,"text":"...and stretches around the world."},{"startTime":854.05,"endTime":857.25,"text":"It was said that Gold Roger,\nKing of the Pirates,"},{"startTime":857.25,"endTime":860.05,"text":"once obtained everything\nthis world has to offer,"},{"startTime":860.05,"endTime":866.99,"text":"and before he died, he said he left\nthe great One Piece treasure there,"},{"startTime":866.99,"endTime":870.93,"text":"so pirates everywhere have since\nset sail for the Grand Line!"},{"startTime":870.93,"endTime":876.6,"text":"It's now an intense battlefield,\nand even called a pirate graveyard!"},{"startTime":880.81,"endTime":883.44,"text":"I've heard from patrons before..."},{"startTime":883.44,"endTime":887.98,"text":"...that whoever enters the Grand\nLine never comes out alive..."},{"startTime":887.98,"endTime":891.49,"text":"But the One Piece\nis somewhere there,"},{"startTime":891.49,"endTime":893.15,"text":"so we're going there!"},{"startTime":893.15,"endTime":894.89,"text":"Guess it can't be helped!"},{"startTime":894.89,"endTime":896.56,"text":"<i>Not you too, Zoro-san?!</i>"},{"startTime":896.56,"endTime":898.69,"text":"What's it matter?\nYou're not going, are you?"},{"startTime":898.69,"endTime":902.03,"text":"N-no, but I'm worried\nabout you!"},{"startTime":902.03,"endTime":903.83,"text":"Is that so wrong?!"},{"startTime":903.83,"endTime":906.83,"text":"<i>Luffy-san and I haven't\nknown each other long,</i>"},{"startTime":906.83,"endTime":908.57,"text":"<i>but we are friends!</i>"},{"startTime":908.57,"endTime":910.04,"text":"Right?"},{"startTime":910.04,"endTime":913.97,"text":"Yeah! We're gonna part ways,\nbut we'll always be friends!"},{"startTime":917.48,"endTime":921.31,"text":"Since I was little kid,\nI've never had friends..."},{"startTime":921.31,"endTime":925.29,"text":"Much less anyone who would\nfight for my sake..."},{"startTime":925.29,"endTime":928.95,"text":"But more than anything, I never\ntried to fight for anything..."},{"startTime":931.09,"endTime":936.33,"text":"But you two taught me how\nto live for my beliefs!"},{"startTime":936.33,"endTime":939.77,"text":"I've decided to make\nmy childhood dream come true!"},{"startTime":939.77,"endTime":941.5,"text":"I want to join the navy!"},{"startTime":941.5,"endTime":945.17,"text":"Shouldn't you be more\nworried about yourself, then?"},{"startTime":946.54,"endTime":948.41,"text":"Even if you were\njust a chore boy,"},{"startTime":948.41,"endTime":951.94,"text":"<i>you did spend two years\non Alvida's pirate ship.</i>"},{"startTime":953.95,"endTime":956.75,"text":"Don't underestimate the navy's\ninfo-gathering skills."},{"startTime":956.75,"endTime":959.95,"text":"If they find out about that,\nyou'll never get to join."},{"startTime":959.95,"endTime":962.18,"text":"N-now that you mention it..."},{"startTime":963.19,"endTime":964.85,"text":"Pardon me!"},{"startTime":969.9,"endTime":972.97,"text":"Is it true that you are pirates?!"},{"startTime":972.97,"endTime":978.44,"text":"Yeah. We gained a member\nand became a pirate group just now!"},{"startTime":978.44,"endTime":983.61,"text":"We appreciate that you saved our base\nand this town from that tyrant!"},{"startTime":983.61,"endTime":986.51,"text":"However, now that we know\nyou are pirates,"},{"startTime":986.51,"endTime":989.18,"text":"in the name of the navy,\nwe cannot stand by quietly!"},{"startTime":991.72,"endTime":994.75,"text":"You will leave this town at once!"},{"startTime":994.75,"endTime":998.53,"text":"Out of obligation, we will refrain\nfrom contacting headquarters."},{"startTime":998.53,"endTime":1001.29,"text":"Hey, navy guy!\nHow can you talk like that?!"},{"startTime":1001.29,"endTime":1005.1,"text":"Even you guys were subdued\nand terrified of Morgan!"},{"startTime":1005.1,"endTime":1008.37,"text":"We owe these people our lives!"},{"startTime":1008.37,"endTime":1009.7,"text":"Yeah! Yeah!"},{"startTime":1013.37,"endTime":1015.54,"text":"Well, guess we should go!"},{"startTime":1015.54,"endTime":1017.31,"text":"Thanks for the food, lady!"},{"startTime":1017.31,"endTime":1020.18,"text":"You guys are leaving already?"},{"startTime":1020.18,"endTime":1021.51,"text":"Yeah."},{"startTime":1028.69,"endTime":1030.46,"text":"Aren't you part of their crew?"},{"startTime":1030.46,"endTime":1032.53,"text":"Eh? I..."},{"startTime":1032.53,"endTime":1033.86,"text":"I'm..."},{"startTime":1038.1,"endTime":1039.43,"text":"Hold it!"},{"startTime":1039.43,"endTime":1041.87,"text":"Well? Is he?!"},{"startTime":1041.87,"endTime":1045.87,"text":"I know what he's done until now."},{"startTime":1045.87,"endTime":1048.38,"text":"<i>Luffy-san! You wouldn't!</i>"},{"startTime":1048.38,"endTime":1051.14,"text":"There was this reaaally\nfat pirate lady,"},{"startTime":1051.14,"endTime":1053.35,"text":"I think her name was Ahiruda."},{"startTime":1053.35,"endTime":1055.38,"text":"<i>Luffy-san!</i>"},{"startTime":1055.38,"endTime":1057.65,"text":"<i>If they find out I was\non a pirate ship,</i>"},{"startTime":1057.65,"endTime":1060.42,"text":"<i>I'll never get\nto join the navy!</i>"},{"startTime":1060.42,"endTime":1065.83,"text":"And she had this iron club.\nMan, she was an ugly hag!"},{"startTime":1065.83,"endTime":1069.7,"text":"And for two whole years,\nthis guy was her-"},{"startTime":1069.7,"endTime":1074.36,"text":"<i>Please don't!\nPlease don't, Luffy-san!</i>"},{"startTime":1083.01,"endTime":1085.18,"text":"Now you've done it,\nyou bastard!"},{"startTime":1085.18,"endTime":1087.84,"text":"Damn you!\nDamn you! Damn you!"},{"startTime":1090.45,"endTime":1091.95,"text":"Stop that!"},{"startTime":1091.95,"endTime":1095.89,"text":"We won't allow you to cause\nany more trouble in this town!"},{"startTime":1095.89,"endTime":1099.38,"text":"Hey! You've gone too far.\nThat's enough."},{"startTime":1105.73,"endTime":1108.37,"text":"It's very clear that you\nguys aren't crewmates!"},{"startTime":1108.37,"endTime":1110.86,"text":"Now leave this town at once!"},{"startTime":1117.31,"endTime":1118.8,"text":"<i>On purpose...</i>"},{"startTime":1120.61,"endTime":1122.95,"text":"<i>He did that on purpose...</i>"},{"startTime":1126.65,"endTime":1129.06,"text":"<i>For me...</i>"},{"startTime":1129.06,"endTime":1132.39,"text":"<i>He purposely got me riled up\nto make me hit him...</i>"},{"startTime":1134.13,"endTime":1139.12,"text":"<i>Even in the very end,\nI wound up relying on him!</i>"},{"startTime":1142.5,"endTime":1145.67,"text":"<i>Nothing's changed at all!</i>"},{"startTime":1147.71,"endTime":1150.48,"text":"<i>Am I an idiot?!</i>"},{"startTime":1150.48,"endTime":1152.61,"text":"Please!"},{"startTime":1152.61,"endTime":1155.72,"text":"Please...\nlet me join the navy!"},{"startTime":1155.72,"endTime":1158.95,"text":"I'll gladly do chores\nor anything else!"},{"startTime":1158.95,"endTime":1161.29,"text":"If it means I can be marine!"},{"startTime":1164.39,"endTime":1167.76,"text":"Lieutenant Colonel!\nI'm against the idea!"},{"startTime":1167.76,"endTime":1170.46,"text":"I still don't fully\ntrust this kid!"},{"startTime":1170.46,"endTime":1174.07,"text":"<i>There have been cases of marines\nbeing pirate spies!</i>"},{"startTime":1174.07,"endTime":1177.07,"text":"We'll first need to conduct\na background check..."},{"startTime":1177.07,"endTime":1180.4,"text":"<i>I'm a man who will become\na navy officer!</i>"},{"startTime":1190.62,"endTime":1193.72,"text":"Countless comrades of ours\nhave been killed by pirates."},{"startTime":1193.72,"endTime":1196.76,"text":"Don't take the navy lightly."},{"startTime":1196.76,"endTime":1197.76,"text":"Then..."},{"startTime":1197.76,"endTime":1199.75,"text":"Permission to join granted!"},{"startTime":1201.63,"endTime":1202.96,"text":"Yes, sir!"},{"startTime":1209.37,"endTime":1211.6,"text":"\"I've flashily taken the map! Buggy\""},{"startTime":1215.31,"endTime":1217.48,"text":"That was a pretty lame act."},{"startTime":1217.48,"endTime":1219.85,"text":"Wouldn't be shocked\nif they saw through it."},{"startTime":1219.85,"endTime":1223.42,"text":"Coby'll handle the rest on\nhis own now. I just know it."},{"startTime":1223.42,"endTime":1225.19,"text":"It's a nice way to leave,\nthough."},{"startTime":1225.19,"endTime":1227.85,"text":"Being unable to turn back\n'cause everyone hates you-"},{"startTime":1227.85,"endTime":1230.46,"text":"it's pirate-like!"},{"startTime":1230.46,"endTime":1231.52,"text":"That's true!"},{"startTime":1231.52,"endTime":1232.86,"text":"<i>Luffy-san!</i>"},{"startTime":1235.26,"endTime":1240.03,"text":"Thank you! I'll never forget\nall you've done for me!"},{"startTime":1240.03,"endTime":1243.9,"text":"<i>I've never heard of a pirate\nbeing thanked by a marine...</i>"},{"startTime":1246.91,"endTime":1249.88,"text":"Let's meet again sometime, Coby!"},{"startTime":1249.88,"endTime":1253.18,"text":"<i>--Luffy-san...\n--Bye!</i>"},{"startTime":1253.18,"endTime":1255.41,"text":"All hands, salute!"},{"startTime":1258.59,"endTime":1262.09,"text":"See ya!"},{"startTime":1262.09,"endTime":1264.32,"text":"That's a great friend\nyou have there."},{"startTime":1269.96,"endTime":1270.99,"text":"Yes, sir!"},{"startTime":1272.23,"endTime":1276.67,"text":"Our salute just now is\nin violation of naval law!"},{"startTime":1276.67,"endTime":1280.67,"text":"Therefore, we will all go without\nfood for three days! Understood?!"},{"startTime":1280.67,"endTime":1282.01,"text":"Yes, sir!"},{"startTime":1285.01,"endTime":1286.35,"text":"<i>I'm sure...</i>"},{"startTime":1286.35,"endTime":1290.02,"text":"<i>I'm sure we'll meet again\nsometime, somewhere, Luffy-san!</i>"},{"startTime":1290.02,"endTime":1294.49,"text":"<i>Even if we're divided\nas pirates and marines...</i>"},{"startTime":1294.49,"endTime":1297.15,"text":"<i>...let's meet again someday!</i>"},{"startTime":1301.86,"endTime":1305.47,"text":"Alright! Our pirate crew\nfinally sets sail!"},{"startTime":1305.47,"endTime":1308.23,"text":"Looks like some pretty good\nadventures'll be waiting for us."},{"startTime":1311.64,"endTime":1314.3,"text":"<i>I will be King of the Pirates!</i>"},{"startTime":1317.14,"endTime":1321.31,"text":"You really seem obsessed about\nthis King of the Pirates thing."},{"startTime":1321.31,"endTime":1322.98,"text":"Is there some sorta reason for it?"},{"startTime":1322.98,"endTime":1325.49,"text":"No reason. It's just..."},{"startTime":1325.49,"endTime":1326.72,"text":"It's just?"},{"startTime":1326.72,"endTime":1330.39,"text":"I swore to a certain man that..."},{"startTime":1330.39,"endTime":1332.66,"text":"...someday I would gather a great crew,"},{"startTime":1332.66,"endTime":1334.66,"text":"find the world's greatest treasure,"},{"startTime":1334.66,"endTime":1336.65,"text":"and become\nKing of the Pirates!"},{"startTime":1342.67,"endTime":1344.83,"text":"This straw hat knows!"},{"startTime":1346.81,"endTime":1348.14,"text":"I see..."},{"startTime":1357.18,"endTime":1359.59,"text":"Alright! Let's go!"},{"startTime":1359.59,"endTime":1363.92,"text":"Set sail for the Grand Line!"},{"startTime":1376.07,"endTime":1386.07,"text":"<i>When I was little, I had\na vision of a treasure map</i>"},{"startTime":1390.28,"endTime":1397.22,"text":"<i>and I always searched\nfor that miraculous place</i>"},{"startTime":1397.22,"endTime":1404.39,"text":"<i>before someone else\ncould beat me to it</i>"},{"startTime":1406.93,"endTime":1416.93,"text":"<i>If the world is going to change</i>"},{"startTime":1418.41,"endTime":1425.42,"text":"<i>before I can even attain my dream</i>"},{"startTime":1425.42,"endTime":1432.49,"text":"<i>then take me to the time\nwhen I knew nothing</i>"},{"startTime":1432.49,"endTime":1442.49,"text":"<i>so that my memories won't fade</i>"}]