import { createHotContext as __vite__createHotContext } from "/@vite/client";import.meta.hot = __vite__createHotContext("/src/components/AniPlayer.css");import { updateStyle as __vite__updateStyle, removeStyle as __vite__removeStyle } from "/@vite/client"
const __vite__id = "E:/Anilab/src/components/AniPlayer.css"
const __vite__css = "/* ══════════════════════════════════════════════════════════════\r\n   AniPlayer — Premium Multi-Device Video Player\r\n   Layout: top-bar  |  spacer (flex-grow)  |  bottom-group\r\n   ══════════════════════════════════════════════════════════════ */\r\n\r\n/* ── Wrapper ───────────────────────────────────────────────── */\r\n.anip {\r\n  position: relative;\r\n  width: 100%;\r\n  aspect-ratio: 16 / 9;\r\n  background: #000;\r\n  overflow: hidden;\r\n  user-select: none;\r\n  -webkit-user-select: none;\r\n  touch-action: none;\r\n  -webkit-tap-highlight-color: transparent;\r\n  font-family: 'Inter', system-ui, -apple-system, sans-serif;\r\n}\r\n.anip--fs {\r\n  position: fixed !important;\r\n  inset: 0 !important;\r\n  width: 100vw  !important;\r\n  height: 100vh !important;\r\n  z-index: 99999 !important;\r\n  aspect-ratio: unset !important;\r\n  background: #000;\r\n}\r\n\r\n/* ── Video ─────────────────────────────────────────────────── */\r\n.anip__video {\r\n  width: 100%;\r\n  height: 100%;\r\n  display: block;\r\n  object-fit: contain;\r\n  background: #000;\r\n  /* Kill the ugly Android WebView grey oval / default play icon */\r\n  -webkit-appearance: none;\r\n  appearance: none;\r\n}\r\n\r\n/* \r\n * This is the nuclear fix: hide the default browser video loading poster\r\n * (the grey oval with black arrow that appears while HLS loads on Android)\r\n */\r\n.anip__video::-webkit-media-controls         { display: none !important; -webkit-appearance: none !important; }\r\n.anip__video::-webkit-media-controls-panel   { display: none !important; -webkit-appearance: none !important; }\r\n.anip__video::-webkit-media-controls-play-button { display: none !important; -webkit-appearance: none !important; }\r\n.anip__video::-webkit-media-controls-start-playback-button { display: none !important; -webkit-appearance: none !important; }\r\n.anip__video:not([src])::-webkit-media-controls { display: none !important; -webkit-appearance: none !important; }\r\n\r\n/* ── Full-screen black loading placeholder ────────────────── */\r\n.anip__loading-bg {\r\n  position: absolute;\r\n  inset: 0;\r\n  background: #000;\r\n  z-index: 9;\r\n  pointer-events: auto;\r\n}\r\n\r\n/* ── Buffering spinner ─────────────────────────────────────── */\r\n.anip__spinner {\r\n  position: absolute;\r\n  inset: 0;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  pointer-events: none;\r\n  z-index: 10;\r\n}\r\n.anip__spinner-ring {\r\n  width: 44px;\r\n  height: 44px;\r\n  border-radius: 50%;\r\n  border: 3.5px solid rgba(255,255,255,0.12);\r\n  border-top-color: rgba(255,255,255,0.85);\r\n  animation: anip-spin 0.9s linear infinite;\r\n}\r\n@keyframes anip-spin { to { transform: rotate(360deg); } }\r\n\r\n/* ── Tap-to-play overlay ───────────────────────────────────── */\r\n.anip__tap-play {\r\n  position: absolute;\r\n  inset: 0;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 14px;\r\n  z-index: 15;\r\n  cursor: pointer;\r\n  background: rgba(0,0,0,0.5);\r\n}\r\n.anip__tap-play__circle {\r\n  width: 80px;\r\n  height: 80px;\r\n  border-radius: 50%;\r\n  background: rgba(229,9,20,0.92);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  box-shadow: 0 0 0 10px rgba(229,9,20,0.18), 0 4px 24px rgba(0,0,0,0.6);\r\n  transition: transform 0.15s ease;\r\n}\r\n.anip__tap-play:active .anip__tap-play__circle { transform: scale(0.92); }\r\n.anip__tap-play__label {\r\n  color: #fff;\r\n  font-size: 15px;\r\n  font-weight: 700;\r\n  letter-spacing: 0.5px;\r\n  text-shadow: 0 1px 6px rgba(0,0,0,0.8);\r\n}\r\n\r\n/* ── Fatal error overlay ───────────────────────────────────── */\r\n.anip__error {\r\n  position: absolute;\r\n  inset: 0;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 12px;\r\n  z-index: 15;\r\n  background: rgba(0,0,0,0.82);\r\n  padding: 24px;\r\n  text-align: center;\r\n}\r\n.anip__error__icon { font-size: 38px; }\r\n.anip__error__msg {\r\n  color: rgba(255,255,255,0.85);\r\n  font-size: 13px;\r\n  line-height: 1.6;\r\n  max-width: 260px;\r\n}\r\n.anip__error__retry {\r\n  margin-top: 6px;\r\n  padding: 10px 28px;\r\n  border-radius: 20px;\r\n  background: #e50914;\r\n  color: #fff;\r\n  border: none;\r\n  font-size: 14px;\r\n  font-weight: 700;\r\n  cursor: pointer;\r\n  letter-spacing: 0.3px;\r\n}\r\n\r\n\r\n/* ══════════════════════════════════════════════════════════════\r\n   OVERLAY — the entire controls layer\r\n   Uses flex column with spacer so controls pin to bottom\r\n   ══════════════════════════════════════════════════════════════ */\r\n.anip__overlay {\r\n  position: absolute;\r\n  inset: 0;\r\n  display: flex;\r\n  flex-direction: column;\r\n  z-index: 20;\r\n  /* hidden by default, revealed by .anip--ctrl */\r\n  opacity: 0;\r\n  pointer-events: none;\r\n  transition: opacity 0.22s ease;\r\n}\r\n.anip--ctrl .anip__overlay {\r\n  opacity: 1;\r\n  pointer-events: all;\r\n}\r\n\r\n/* ── Top bar ───────────────────────────────────────────────── */\r\n.anip__top-bar {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 10px;\r\n  padding: 14px 14px 40px;\r\n  background: linear-gradient(to bottom, rgba(0,0,0,0.80) 0%, transparent 100%);\r\n  /* pointer-events so back button is always clickable */\r\n  pointer-events: all;\r\n}\r\n\r\n.anip__back-btn {\r\n  flex-shrink: 0;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  width: 34px;\r\n  height: 34px;\r\n  border-radius: 50%;\r\n  background: rgba(0,0,0,0.65);\r\n  border: 1px solid rgba(255,255,255,0.22);\r\n  color: #fff;\r\n  cursor: pointer;\r\n  /* NO backdrop-filter — it creates a GPU compositing layer\r\n     that conflicts with the video decoder surface → black frames */\r\n  transition: background 0.15s, transform 0.12s;\r\n  touch-action: manipulation;\r\n  -webkit-tap-highlight-color: transparent;\r\n}\r\n.anip__back-btn:hover  { background: rgba(255,255,255,0.2); }\r\n.anip__back-btn:active { transform: scale(0.88); }\r\n\r\n.anip__title {\r\n  flex: 1;\r\n  min-width: 0;\r\n  font-size: 13px;\r\n  font-weight: 600;\r\n  color: #fff;\r\n  opacity: 0.9;\r\n  white-space: nowrap;\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n  text-shadow: 0 1px 6px rgba(0,0,0,0.9);\r\n}\r\n\r\n/* ── Spacer (middle area, clicking toggles controls) ───────── */\r\n.anip__spacer {\r\n  flex: 1;\r\n  min-height: 0;\r\n}\r\n\r\n/* ══════════════════════════════════════════════════════════════\r\n   BOTTOM GROUP — seek bar + controls bar, pinned to bottom\r\n   ══════════════════════════════════════════════════════════════ */\r\n.anip__bottom-group {\r\n  background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 100%);\r\n  padding: 0 14px 10px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 0;\r\n  pointer-events: all;\r\n}\r\n\r\n/* ── Seek bar ──────────────────────────────────────────────── */\r\n.anip__seek-wrap {\r\n  width: 100%;\r\n  padding: 10px 0 6px;\r\n  cursor: pointer;\r\n  touch-action: none;\r\n}\r\n.anip__seek-track {\r\n  position: relative;\r\n  width: 100%;\r\n  height: 4px;\r\n  background: rgba(255,255,255,0.25);\r\n  border-radius: 99px;\r\n  transition: height 0.15s ease;\r\n}\r\n.anip__seek-wrap:hover .anip__seek-track { height: 6px; }\r\n.anip__seek-buf {\r\n  position: absolute;\r\n  left: 0; top: 0; bottom: 0;\r\n  background: rgba(255,255,255,0.32);\r\n  border-radius: 99px;\r\n  pointer-events: none;\r\n}\r\n.anip__seek-played {\r\n  position: absolute;\r\n  left: 0; top: 0; bottom: 0;\r\n  background: #e50914;\r\n  border-radius: 99px;\r\n  pointer-events: none;\r\n}\r\n.anip__seek-knob {\r\n  position: absolute;\r\n  right: -7px;\r\n  top: 50%;\r\n  transform: translateY(-50%) scale(0);\r\n  width: 15px;\r\n  height: 15px;\r\n  border-radius: 50%;\r\n  background: #e50914;\r\n  border: 2px solid #fff;\r\n  box-shadow: 0 0 8px rgba(229,9,20,0.6);\r\n  transition: transform 0.15s ease;\r\n}\r\n.anip__seek-wrap:hover .anip__seek-knob,\r\n.anip--touch .anip__seek-knob {\r\n  transform: translateY(-50%) scale(1);\r\n}\r\n\r\n/* ── Controls bar ──────────────────────────────────────────── */\r\n.anip__bar {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  gap: 4px;\r\n}\r\n\r\n/* ── Clusters ──────────────────────────────────────────────── */\r\n.anip__cluster {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 2px;\r\n  flex-shrink: 0;\r\n}\r\n.anip__cluster--right { margin-left: auto; }\r\n\r\n/* ── Generic button ────────────────────────────────────────── */\r\n.anip__btn {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  gap: 5px;\r\n  background: transparent;\r\n  border: none;\r\n  color: rgba(255,255,255,0.9);\r\n  padding: 9px 9px;\r\n  border-radius: 8px;\r\n  cursor: pointer;\r\n  line-height: 1;\r\n  transition: background 0.13s, transform 0.1s, color 0.13s;\r\n  -webkit-tap-highlight-color: transparent;\r\n  touch-action: manipulation;\r\n  white-space: nowrap;\r\n}\r\n.anip__btn:hover  { background: rgba(255,255,255,0.12); color: #fff; }\r\n.anip__btn:active { transform: scale(0.88); }\r\n.anip__btn--active { color: #e50914; }\r\n\r\n/* Play button slightly larger hit area */\r\n.anip__btn--play { padding: 9px 11px; }\r\n\r\n/* Skip button — icon + small number overlay */\r\n.anip__btn--skip { position: relative; padding: 9px 8px 14px; }\r\n.anip__skip-num {\r\n  position: absolute;\r\n  bottom: 5px;\r\n  left: 50%;\r\n  transform: translateX(-50%);\r\n  font-size: 8px;\r\n  font-weight: 800;\r\n  color: rgba(255,255,255,0.85);\r\n  line-height: 1;\r\n  letter-spacing: 0.2px;\r\n}\r\n\r\n/* Quality badge next to settings icon */\r\n.anip__badge {\r\n  font-size: 10px;\r\n  font-weight: 700;\r\n  color: rgba(255,255,255,0.8);\r\n  letter-spacing: 0.3px;\r\n}\r\n\r\n/* ── Time display ──────────────────────────────────────────── */\r\n.anip__time {\r\n  font-size: 12px;\r\n  font-weight: 600;\r\n  color: rgba(255,255,255,0.85);\r\n  white-space: nowrap;\r\n  padding: 0 6px;\r\n  letter-spacing: 0.2px;\r\n}\r\n\r\n/* ── Volume slider (desktop only, hidden on touch) ─────────── */\r\n.anip__vol {\r\n  -webkit-appearance: none;\r\n  appearance: none;\r\n  width: 72px;\r\n  height: 4px;\r\n  background: rgba(255,255,255,0.28);\r\n  border-radius: 99px;\r\n  outline: none;\r\n  cursor: pointer;\r\n  display: block;\r\n}\r\n.anip__vol::-webkit-slider-thumb {\r\n  -webkit-appearance: none;\r\n  width: 12px;\r\n  height: 12px;\r\n  border-radius: 50%;\r\n  background: #e50914;\r\n  border: 2px solid #fff;\r\n  box-shadow: 0 0 4px rgba(229,9,20,0.5);\r\n  cursor: pointer;\r\n}\r\n.anip__vol::-moz-range-thumb {\r\n  width: 12px;\r\n  height: 12px;\r\n  border-radius: 50%;\r\n  background: #e50914;\r\n  border: 2px solid #fff;\r\n  cursor: pointer;\r\n}\r\n\r\n/* ── Popup menus ───────────────────────────────────────────── */\r\n.anip__menu-anchor { position: relative; }\r\n.anip__menu {\r\n  position: absolute;\r\n  bottom: calc(100% + 10px);\r\n  right: 0;\r\n  min-width: 150px;\r\n  max-height: 240px;\r\n  overflow-y: auto;\r\n  background: rgba(8,8,12,0.97);\r\n  border: 1px solid rgba(255,255,255,0.1);\r\n  border-radius: 14px;\r\n  padding: 8px 6px;\r\n  box-shadow: 0 16px 48px rgba(0,0,0,0.75);\r\n  z-index: 99;\r\n  animation: anip-menu-pop 0.18s cubic-bezier(0.34,1.56,0.64,1);\r\n}\r\n@keyframes anip-menu-pop {\r\n  from { opacity:0; transform: translateY(6px) scale(0.94); }\r\n  to   { opacity:1; transform: translateY(0) scale(1); }\r\n}\r\n.anip__menu-hd {\r\n  font-size: 9px;\r\n  font-weight: 800;\r\n  text-transform: uppercase;\r\n  letter-spacing: 1.2px;\r\n  color: rgba(255,255,255,0.38);\r\n  padding: 4px 12px 8px;\r\n  margin: 0;\r\n  border-bottom: 1px solid rgba(255,255,255,0.07);\r\n  margin-bottom: 4px;\r\n}\r\n.anip__menu-item {\r\n  display: flex;\r\n  align-items: center;\r\n  width: 100%;\r\n  background: none;\r\n  border: none;\r\n  color: rgba(255,255,255,0.8);\r\n  padding: 10px 12px;\r\n  font-size: 14px;\r\n  font-weight: 500;\r\n  border-radius: 9px;\r\n  cursor: pointer;\r\n  text-align: left;\r\n  transition: background 0.12s, color 0.12s;\r\n  touch-action: manipulation;\r\n}\r\n.anip__menu-item:hover { background: rgba(255,255,255,0.08); color: #fff; }\r\n.anip__menu-item--on   { color: #e50914; font-weight: 700; }\r\n.anip__chk             { color: #e50914; margin-right: 6px; font-weight: 900; }\r\n.anip__menu-empty {\r\n  font-size: 12px;\r\n  color: rgba(255,255,255,0.32);\r\n  text-align: center;\r\n  padding: 10px 12px;\r\n  margin: 0;\r\n}\r\n\r\n/* ══════════════════════════════════════════════════════════════\r\n   SKIP RIPPLES (double-tap feedback)\r\n   ══════════════════════════════════════════════════════════════ */\r\n.anip-ripple {\r\n  position: absolute;\r\n  top: 50%;\r\n  transform: translateY(-50%);\r\n  pointer-events: none;\r\n  z-index: 30;\r\n}\r\n.anip-ripple--left  { left:  8%; }\r\n.anip-ripple--right { right: 8%; }\r\n\r\n.anip-ripple__ring {\r\n  position: absolute;\r\n  top: 50%; left: 50%;\r\n  transform: translate(-50%,-50%);\r\n  width: 90px; height: 90px;\r\n  border-radius: 50%;\r\n  border: 2px solid rgba(255,255,255,0.4);\r\n  animation: anip-ring 0.7s ease forwards;\r\n}\r\n.anip-ripple__ring--2 {\r\n  width: 114px; height: 114px;\r\n  border-color: rgba(255,255,255,0.18);\r\n  animation-delay: 0.08s;\r\n}\r\n@keyframes anip-ring {\r\n  0%   { opacity:0.9; transform: translate(-50%,-50%) scale(0.4); }\r\n  100% { opacity:0;   transform: translate(-50%,-50%) scale(1.2); }\r\n}\r\n.anip-ripple__inner {\r\n  width: 80px; height: 80px;\r\n  border-radius: 50%;\r\n  background: rgba(255,255,255,0.22);\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 4px;\r\n  color: #fff;\r\n  animation: anip-inner 0.7s ease forwards;\r\n}\r\n.anip-ripple__inner span {\r\n  font-size: 11px;\r\n  font-weight: 800;\r\n  letter-spacing: 0.3px;\r\n}\r\n@keyframes anip-inner {\r\n  0%   { opacity:1; transform: scale(0.7); }\r\n  40%  { opacity:1; transform: scale(1.05); }\r\n  100% { opacity:0; transform: scale(1); }\r\n}\r\n\r\n/* ══════════════════════════════════════════════════════════════\r\n   SWIPE INDICATORS (brightness / volume)\r\n   ══════════════════════════════════════════════════════════════ */\r\n.anip-swipe {\r\n  position: absolute;\r\n  top: 50%;\r\n  transform: translateY(-50%) scale(0.85);\r\n  opacity: 0;\r\n  transition: opacity 0.18s, transform 0.18s;\r\n  pointer-events: none;\r\n  z-index: 40;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  gap: 8px;\r\n  background: rgba(0,0,0,0.72);\r\n  border: 1px solid rgba(255,255,255,0.12);\r\n  border-radius: 18px;\r\n  padding: 16px 13px;\r\n}\r\n.anip-swipe--on {\r\n  opacity: 1;\r\n  transform: translateY(-50%) scale(1);\r\n}\r\n.anip-swipe--brightness { left:  4%; }\r\n.anip-swipe--volume     { right: 4%; }\r\n.anip-swipe__icon { font-size: 18px; line-height: 1; }\r\n.anip-swipe__track {\r\n  width: 6px; height: 80px;\r\n  background: rgba(255,255,255,0.18);\r\n  border-radius: 99px;\r\n  position: relative;\r\n  overflow: hidden;\r\n}\r\n.anip-swipe__fill {\r\n  position: absolute;\r\n  bottom: 0; left: 0; right: 0;\r\n  background: linear-gradient(to top, #e50914, #ff6b6b);\r\n  border-radius: 99px;\r\n  transition: height 0.08s linear;\r\n}\r\n.anip-swipe__pct {\r\n  font-size: 11px;\r\n  font-weight: 700;\r\n  color: #fff;\r\n  letter-spacing: 0.3px;\r\n}\r\n\r\n/* ══════════════════════════════════════════════════════════════\r\n   RESPONSIVE\r\n   ══════════════════════════════════════════════════════════════ */\r\n\r\n/* Mobile ≤ 540px */\r\n@media (max-width: 540px) {\r\n  .anip__top-bar    { padding: 10px 12px 32px; }\r\n  .anip__title      { font-size: 11px; }\r\n  .anip__bottom-group { padding: 0 10px 8px; }\r\n  .anip__bar        { gap: 0; }\r\n  .anip__btn        { padding: 8px 7px; }\r\n  .anip__btn--play  { padding: 8px 9px; }\r\n  .anip__btn--skip  { padding: 8px 6px 13px; }\r\n  .anip__time       { font-size: 10px; padding: 0 3px; }\r\n  .anip__badge      { display: none; }\r\n  .anip__vol        { display: none; }   /* use swipe gesture on mobile */\r\n  .anip__back-btn   { width: 30px; height: 30px; }\r\n  .anip-swipe__track { height: 60px; }\r\n}\r\n\r\n/* Small tablet 541–768px */\r\n@media (min-width: 541px) and (max-width: 768px) {\r\n  .anip__vol  { display: none; }         /* swipe for volume on tablet too */\r\n  .anip__badge { display: none; }\r\n}\r\n\r\n/* Desktop ≥ 769px — cursor hides when inactive */\r\n@media (min-width: 769px) {\r\n  .anip        { cursor: none; }\r\n  .anip--ctrl  { cursor: default; }\r\n  .anip__btn   { padding: 9px 10px; }\r\n  .anip__vol   { width: 80px; }\r\n}\r\n\r\n/* Large screens ≥ 1200px */\r\n@media (min-width: 1200px) {\r\n  .anip__title   { font-size: 14px; }\r\n  .anip__time    { font-size: 13px; }\r\n  .anip__vol     { width: 96px; }\r\n}\r\n\r\n/* Fullscreen — always show volume slider */\r\n.anip--fs .anip__vol          { display: block !important; }\r\n.anip--fs .anip__badge        { display: inline !important; }\r\n.anip--fs .anip__bottom-group { padding: 0 20px 18px; }\r\n.anip--fs .anip__top-bar      { padding: 18px 20px 44px; }\r\n.anip--fs .anip__title        { font-size: 15px; }\r\n\r\n/* ── Developer Diagnostics Panel ───────────────────────────── */\r\n.anip__debug-panel {\r\n  position: absolute;\r\n  bottom: 0;\r\n  left: 0;\r\n  right: 0;\r\n  height: 55%;\r\n  background: rgba(8, 8, 8, 0.94);\r\n  border-top: 1.5px solid rgba(229, 9, 20, 0.5);\r\n  z-index: 999;\r\n  display: flex;\r\n  flex-direction: column;\r\n  color: #eee;\r\n  font-family: monospace;\r\n  font-size: 11px;\r\n}\r\n.anip__debug-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: spa