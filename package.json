{
  "name": "anilab",
  "private": true,
  "version": "1.5.4",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"VITE,PROXY\" --prefix-colors \"cyan,magenta\" \"node --insecure-http-parser ./node_modules/vite/bin/vite.js --host\" \"node --insecure-http-parser server/proxy.mjs\"",
    "dev:py": "concurrently --names \"VITE,PY_PROXY\" --prefix-colors \"cyan,blue\" \"vite --host\" \"python -m uvicorn app.main:app --app-dir my-anime-api --port 4000 --reload\"",
    "proxy": "node --insecure-http-parser server/proxy.mjs",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "build:local": "vite build --mode local",
    "start": "node --insecure-http-parser server/proxy.mjs",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-updater": "^8.50.2",
    "@consumet/extensions": "^1.8.8",
    "@supabase/supabase-js": "^2.110.1",
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "got-scraping": "^4.2.1",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.21.0",
    "pg": "^8.22.0",
    "playwright": "^1.61.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-core": "^25.2.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "undici": "^8.5.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "oxlint": "^1.69.0",
    "vite": "^8.1.0"
  }
}
