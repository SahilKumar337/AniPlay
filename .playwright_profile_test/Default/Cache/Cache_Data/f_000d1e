const __vite__css = "/* ============================================================\r\n   AniLab – Global Design System\r\n   Dark theme with red accent (#e50914)\r\n   ============================================================ */\r\n\r\n/* ---------- Reset & Base ---------- */\r\n*, *::before, *::after { \r\n  box-sizing: border-box; \r\n  margin: 0; \r\n  padding: 0; \r\n  -webkit-tap-highlight-color: transparent !important;\r\n  -webkit-touch-callout: none;\r\n}\r\n\r\n*:focus {\r\n  outline: none !important;\r\n}\r\n\r\n:root {\r\n  --bg-primary:   #0f0f0f;\r\n  --bg-secondary: #181818;\r\n  --bg-card:      #1e1e1e;\r\n  --bg-hover:     #262626;\r\n  --accent:       #e50914;\r\n  --accent-hover: #ff1a26;\r\n  --accent-dim:   rgba(229,9,20,0.15);\r\n  --text-primary:   #ffffff;\r\n  --text-secondary: #a0a0a0;\r\n  --text-muted:     #666666;\r\n  --border:       rgba(255,255,255,0.08);\r\n  --radius-sm:    8px;\r\n  --radius-md:    12px;\r\n  --radius-lg:    16px;\r\n  --radius-xl:    24px;\r\n  --shadow-card:  0 4px 20px rgba(0,0,0,0.5);\r\n  --shadow-glow:  0 0 20px rgba(229,9,20,0.3);\r\n  --nav-height:   56px;\r\n  --transition:   0.2s ease;\r\n  --font-main:    'Inter', sans-serif;\r\n  --font-brand:   'Outfit', sans-serif;\r\n}\r\n\r\nhtml { \r\n  scroll-behavior: smooth; \r\n  -webkit-text-size-adjust: 100%;\r\n  overscroll-behavior-y: none;\r\n  overscroll-behavior: none;\r\n}\r\n\r\nbody {\r\n  font-family: var(--font-main);\r\n  background: var(--bg-primary);\r\n  color: var(--text-primary);\r\n  min-height: 100vh;\r\n  overflow-x: hidden;\r\n  -webkit-font-smoothing: antialiased;\r\n  \r\n  /* Disable select & callouts completely */\r\n  -webkit-user-select: none;\r\n  -webkit-touch-callout: none;\r\n  user-select: none;\r\n  \r\n  /* Disable pull-to-refresh & overscroll bounce */\r\n  overscroll-behavior-y: none;\r\n  overscroll-behavior: none;\r\n}\r\n\r\nimg { display: block; max-width: 100%; }\r\na  { text-decoration: none; color: inherit; outline: none; }\r\nbutton { cursor: pointer; border: none; background: none; font-family: inherit; outline: none; }\r\ninput  { font-family: inherit; outline: none; }\r\nul, ol { list-style: none; }\r\n\r\n/* ---------- Hide Scrollbars globally ---------- */\r\n::-webkit-scrollbar {\r\n  display: none !important;\r\n}\r\n\r\n/* ---------- Layout ---------- */\r\n.app-container {\r\n  width: 100%;\r\n  max-width: 100%;\r\n  margin: 0;\r\n  background: var(--bg-primary);\r\n  min-height: 100vh;\r\n  position: relative;\r\n  overflow: hidden;\r\n}\r\n\r\n@media (min-width: 768px) {\r\n  .app-container {\r\n    max-width: 480px;\r\n    margin: 0 auto;\r\n    border-left: 1px solid var(--border);\r\n    border-right: 1px solid var(--border);\r\n  }\r\n}\r\n\r\n/* ---------- Page wrapper (with bottom nav space) ---------- */\r\n.page {\r\n  padding-bottom: calc(var(--nav-height) + 32px + env(safe-area-inset-bottom));\r\n  min-height: 100vh;\r\n  position: relative;\r\n}\r\n\r\n/* ---------- Buttons ---------- */\r\n.btn {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  gap: 6px;\r\n  padding: 10px 20px;\r\n  border-radius: 50px;\r\n  font-size: 14px;\r\n  font-weight: 600;\r\n  transition: all var(--transition);\r\n  white-space: nowrap;\r\n}\r\n\r\n.btn-primary {\r\n  background: var(--accent);\r\n  color: #fff;\r\n}\r\n.btn-primary:hover { background: var(--accent-hover); transform: scale(1.03); box-shadow: var(--shadow-glow); }\r\n\r\n.btn-outline {\r\n  background: rgba(255,255,255,0.12);\r\n  color: #fff;\r\n  border: 1px solid rgba(255,255,255,0.2);\r\n  backdrop-filter: blur(8px);\r\n}\r\n.btn-outline:hover { background: rgba(255,255,255,0.2); }\r\n\r\n.btn-sm { padding: 7px 14px; font-size: 12px; }\r\n\r\n/* ---------- Section Header ---------- */\r\n.section-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  padding: 0 16px;\r\n  margin-bottom: 12px;\r\n}\r\n.section-title {\r\n  font-size: 16px;\r\n  font-weight: 700;\r\n  font-family: var(--font-brand);\r\n}\r\n.see-all {\r\n  font-size: 13px;\r\n  color: var(--accent);\r\n  font-weight: 600;\r\n  transition: opacity var(--transition);\r\n}\r\n.see-all:hover { opacity: 0.8; }\r\n\r\n/* ---------- Horizontal Scroll Row ---------- */\r\n.h-scroll {\r\n  display: flex;\r\n  gap: 12px;\r\n  overflow-x: auto;\r\n  padding: 0 16px 8px;\r\n  scroll-snap-type: x mandatory;\r\n  -webkit-overflow-scrolling: touch;\r\n}\r\n.h-scroll::-webkit-scrollbar { display: none; }\r\n.h-scroll > * { scroll-snap-align: start; flex-shrink: 0; }\r\n\r\n/* ---------- Anime Card ---------- */\r\n.anime-card {\r\n  position: relative;\r\n  border-radius: var(--radius-md);\r\n  overflow: hidden;\r\n  background: var(--bg-card);\r\n  cursor: pointer;\r\n  transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);\r\n  will-change: transform;\r\n}\r\n.anime-card:hover {\r\n  transform: scale(1.05) translateY(-4px);\r\n  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.5), 0 0 12px rgba(229, 9, 20, 0.35);\r\n  z-index: 5;\r\n}\r\n.anime-card:active {\r\n  transform: scale(0.97) translateY(0);\r\n}\r\n\r\n.anime-card img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.anime-card .card-overlay {\r\n  position: absolute;\r\n  bottom: 0; left: 0; right: 0;\r\n  background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 100%);\r\n  padding: 24px 8px 8px;\r\n}\r\n\r\n.card-rank {\r\n  position: absolute;\r\n  bottom: 6px;\r\n  left: 8px;\r\n  font-size: 28px;\r\n  font-weight: 900;\r\n  font-family: var(--font-brand);\r\n  color: #fff;\r\n  text-shadow: 0 2px 8px rgba(0,0,0,0.8);\r\n  line-height: 1;\r\n}\r\n\r\n.card-badge {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  gap: 3px;\r\n  padding: 2px 6px;\r\n  border-radius: 4px;\r\n  font-size: 10px;\r\n  font-weight: 700;\r\n  text-transform: uppercase;\r\n  letter-spacing: 0.5px;\r\n}\r\n.badge-hd   { background: var(--accent); color: #fff; }\r\n.badge-pg   { background: rgba(255,255,255,0.15); color: #fff; border: 1px solid rgba(255,255,255,0.3); }\r\n.badge-sub  { background: #1a6fa8; color: #fff; }\r\n.badge-dub  { background: #2d6b31; color: #fff; }\r\n\r\n.card-badges {\r\n  position: absolute;\r\n  top: 8px;\r\n  left: 8px;\r\n  display: flex;\r\n  gap: 4px;\r\n}\r\n\r\n/* ---------- Genre Quick Row (Home page) ---------- */\r\n.genre-quick-row {\r\n  display: flex;\r\n  gap: 8px;\r\n  overflow-x: auto;\r\n  padding: 12px 16px 4px;\r\n  scroll-snap-type: x mandatory;\r\n}\r\n.genre-quick-row::-webkit-scrollbar { display: none; }\r\n.genre-quick-pill {\r\n  padding: 6px 14px;\r\n  border-radius: 20px;\r\n  background: var(--bg-card);\r\n  border: 1px solid var(--border);\r\n  font-size: 12px; font-weight: 500;\r\n  white-space: nowrap; cursor: pointer;\r\n  flex-shrink: 0;\r\n  scroll-snap-align: start;\r\n  transition: all var(--transition);\r\n  color: var(--text-secondary);\r\n}\r\n.genre-quick-pill:hover, .genre-quick-pill.active {\r\n  background: var(--accent);\r\n  border-color: var(--accent);\r\n  color: #fff;\r\n}\r\n\r\n/* ---------- Player Page ---------- */\r\n.player-container {\r\n  position: relative;\r\n  width: 100%;\r\n  background: #000;\r\n  aspect-ratio: 16/9;\r\n}\r\n.player-iframe {\r\n  width: 100%; height: 100%; border: none; display: block;\r\n}\r\n.player-back {\r\n  position: absolute;\r\n  top: 10px; left: 10px;\r\n  width: 32px; height: 32px; border-radius: 50%;\r\n  background: rgba(0,0,0,0.6);\r\n  display: flex; align-items: center; justify-content: center;\r\n  cursor: pointer; z-index: 5;\r\n  backdrop-filter: blur(4px);\r\n}\r\n.player-info { padding: 14px 16px; }\r\n.player-title { font-size: 16px; font-weight: 700; margin-bottom: 4px; }\r\n.player-ep-info { font-size: 13px; color: var(--text-secondary); margin-bottom: 14px; }\r\n\r\n/* ---------- Welcome Screen ---------- */\r\n.welcome-screen {\r\n  position: fixed;\r\n  inset: 0;\r\n  z-index: 1000;\r\n  background: var(--bg-primary);\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n.welcome-hero {\r\n  flex: 1;\r\n  position: relative;\r\n  overflow: hidden;\r\n}\r\n.welcome-collage {\r\n  display: grid;\r\n  grid-template-rows: 1fr 1fr 1fr;\r\n  gap: 2px;\r\n  height: 100%;\r\n}\r\n.welcome-collage-row {\r\n  display: flex;\r\n  gap: 2px;\r\n  overflow: hidden;\r\n}\r\n.welcome-collage-row img {\r\n  flex: 1;\r\n  object-fit: cover;\r\n  height: 100%;\r\n  width: 0;\r\n}\r\n.welcome-overlay {\r\n  position: absolute;\r\n  inset: 0;\r\n  background: linear-gradient(\r\n    to bottom,\r\n    rgba(15,15,15,0.2) 0%,\r\n    rgba(15,15,15,0.5) 50%,\r\n    rgba(15,15,15,1) 90%\r\n  );\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: flex-end;\r\n  padding: 28px 24px;\r\n}\r\n.welcome-logo {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 10px;\r\n  margin-bottom: 16px;\r\n}\r\n.welcome-logo-icon {\r\n  width: 44px;\r\n  height: 44px;\r\n  background: var(--accent);\r\n  border-radius: 12px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 22px;\r\n  font-weight: 900;\r\n  font-family: var(--font-brand);\r\n  color: #fff;\r\n}\r\n.welcome-text h1 {\r\n  font-size: 32px;\r\n  font-weight: 900;\r\n  font-family: var(--font-brand);\r\n  line-height: 1.1;\r\n}\r\n.welcome-text h1 span { color: var(--accent); }\r\n.welcome-text p {\r\n  font-size: 15px;\r\n  color: var(--text-secondary);\r\n  margin-top: 6px;\r\n}\r\n.welcome-dots {\r\n  display: flex;\r\n  gap: 6px;\r\n  margin-top: 16px;\r\n}\r\n.welcome-dot {\r\n  width: 8px; height: 8px;\r\n  border-radius: 50%;\r\n  background: rgba(255,255,255,0.3);\r\n  transition: all var(--transition);\r\n}\r\n.welcome-dot.active { background: var(--accent); width: 20px; border-radius: 4px; }\r\n.welcome-actions {\r\n  padding: 20px 24px 40px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 12px;\r\n}\r\n.welcome-actions .btn { width: 100%; justify-content: center; padding: 14px; font-size: 16px; }\r\n\r\n/* ---------- Navbar ---------- */\r\n.navbar {\r\n  position: fixed;\r\n  bottom: 0;\r\n  left: 0;\r\n  right: 0;\r\n  transform: none;\r\n  width: 100%;\r\n  max-width: 100%;\r\n  height: calc(var(--nav-height) + env(safe-area-inset-bottom));\r\n  padding-bottom: env(safe-area-inset-bottom);\r\n  background: rgba(15, 15, 15, 0.94);\r\n  backdrop-filter: blur(24px) saturate(180%);\r\n  -webkit-backdrop-filter: blur(24px) saturate(180%);\r\n  border-top: 1px solid rgba(255, 255, 255, 0.08);\r\n  border-radius: 0;\r\n  box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.4);\r\n  display: flex;\r\n  align-items: center;\r\n  z-index: 100;\r\n  padding: 0 16px;\r\n  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\r\n}\r\n\r\n@media (min-width: 768px) {\r\n  .navbar {\r\n    left: 50%;\r\n    transform: translateX(-50%);\r\n    max-width: 480px;\r\n    border-left: 1px solid rgba(255, 255, 255, 0.08);\r\n    border-right: 1px solid rgba(255, 255, 255, 0.08);\r\n  }\r\n}\r\n.nav-items {\r\n  display: flex;\r\n  width: 100%;\r\n  height: 100%;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n}\r\n.nav-item {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 3px;\r\n  height: 100%;\r\n  border-radius: 20px;\r\n  cursor: pointer;\r\n  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);\r\n  position: relative;\r\n  flex: 1;\r\n  background: transparent !important;\r\n  border: none;\r\n  outline: none !important;\r\n  box-shadow: none !important;\r\n}\r\n.nav-item:focus, .nav-item:active, .nav-item:hover {\r\n  background: transparent !important;\r\n  outline: none !important;\r\n  box-shadow: none !important;\r\n}\r\n.nav-item span {\r\n  font-size: 10px;\r\n  font-weight: 600;\r\n  color: var(--text-muted);\r\n  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);\r\n  letter-spacing: 0.1px;\r\n}\r\n.nav-item svg {\r\n  color: var(--text-muted);\r\n  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);\r\n}\r\n.nav-item.active svg {\r\n  color: var(--accent);\r\n  transform: translateY(-2px) scale(1.1);\r\n  filter: drop-shadow(0 2px 8px rgba(229, 9, 20, 0.5));\r\n}\r\n.nav-item.active span {\r\n  color: var(--accent);\r\n  transform: scale(1.05);\r\n  font-weight: 700;\r\n}\r\n.nav-item.active::after {\r\n  content: '';\r\n  position: absolute;\r\n  bottom: 4px;\r\n  width: 4px;\r\n  height: 4px;\r\n  background: var(--accent);\r\n  border-radius: 50%;\r\n  box-shadow: 0 0 8px var(--accent);\r\n  animation: navDotPop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);\r\n}\r\n@keyframes navDotPop {\r\n  0% { transform: scale(0); opacity: 0; }\r\n  100% { transform: scale(1); opacity: 1; }\r\n}\r\n.nav-item:hover:not(.active) svg {\r\n  color: var(--text-primary);\r\n  transform: translateY(-1px);\r\n}\r\n.nav-item:hover:not(.active) span {\r\n  color: var(--text-primary);\r\n}\r\n\r\n/* ---------- Top Header ---------- */\r\n.top-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  padding: 16px 16px 0;\r\n  position: relative;\r\n  z-index: 10;\r\n}\r\n.top-header .logo {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n}\r\n.logo-badge {\r\n  width: 32px; height: 32px;\r\n  background: var(--accent);\r\n  border-radius: 8px;\r\n  display: flex; align-items: center; justify-content: center;\r\n  font-size: 16px; font-weight: 900;\r\n  font-family: var(--font-brand);\r\n  color: #fff;\r\n}\r\n.header-actions {\r\n  display: flex;\r\n  gap: 12px;\r\n  align-items: center;\r\n}\r\n.icon-btn {\r\n  width: 36px; height: 36px;\r\n  border-radius: 50%;\r\n  background: rgba(255,255,255,0.08);\r\n  display: flex; align-items: center; justify-content: center;\r\n  transition: all var(--transition);\r\n}\r\n.icon-btn:hover { background: rgba(255,255,255,0.16); }\r\n\r\n/* ---------- Home Sections ---------- */\r\n.home-section { margin-bottom